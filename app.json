{
  "expo": {
    "name": "train-zoo",
    "slug": "train-zoo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trainzoo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.anonymous.train-zoo",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["line", "instagram", "instagram-stories", "twitter", "fb"]
      }
    },
    "web": {
      "favicon": "./assets/images/icons/logo.svg"
    },
    
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}